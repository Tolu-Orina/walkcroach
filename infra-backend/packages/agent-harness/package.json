{
  "name": "@walkcroach/agent-harness",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke:memory": "node --import tsx src/smoke-memory.ts",
    "smoke:loop": "node --import tsx src/smoke-loop.ts",
    "local:demo": "node --import tsx src/run-local-demo.ts"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.800.0",
    "@walkcroach/db": "*"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
