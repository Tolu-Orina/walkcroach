{
  "name": "@walkcroach/chrome",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "description": "WalkCroach Chrome — Manifest V3 SME copilot extension",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "zip:prod": "node scripts/zip-prod.mjs",
    "screenshots": "node store/screenshots/capture.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.326",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitest/coverage-v8": "^3.2.7",
    "@wxt-dev/module-react": "^1.1.3",
    "typescript": "^5.8.0",
    "vitest": "^3.2.4",
    "wxt": "^0.20.6"
  },
  "engines": {
    "node": ">=20"
  }
}
