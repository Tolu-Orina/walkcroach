# Local development — copy to `.env.local` and adjust.
# Prod builds get these from SSM via web/buildspec.yml (CodeBuild).

VITE_API_URL=http://localhost:8787

# Dev auth: fake Bearer dev:user:* / dev:anon:* tokens (no Cognito).
# Set to false to test in-app Cognito locally.
VITE_ALLOW_DEV_AUTH=true

# In-app Cognito (USER_PASSWORD_AUTH via cognito-idp API — no Hosted UI).
# VITE_COGNITO_CLIENT_ID=
# VITE_COGNITO_REGION=eu-west-2

# GitHub App connect (set in prod via SSM app_slug → VITE_GITHUB_APP_ENABLED=true)
# VITE_GITHUB_APP_ENABLED=true
# VITE_ALLOW_GITHUB_PAT=false
