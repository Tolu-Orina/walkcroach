{
  "name": "@walkcroach/agent-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "WalkCroach IDE/CLI agent engine — no vscode imports",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "smoke:ping": "node --import tsx src/smoke-ping.ts"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.800.0",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^3.2.7",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
