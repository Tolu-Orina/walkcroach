# CockroachDB
CRDB_CONNECTION_STRING=postgresql://user:password@host:26257/walkcroach?sslmode=verify-full
CRDB_MCP_URL=https://cockroachlabs.cloud/mcp
CRDB_MCP_API_KEY=

# AWS / Bedrock
AWS_REGION=eu-west-2
BEDROCK_NOVA_MODEL_ID=global.amazon.nova-2-lite-v1:0
BEDROCK_TITAN_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0
