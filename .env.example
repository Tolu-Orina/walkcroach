AWS_BEARER_TOKEN_BEDROCK=

# App (web build-time — set by CI from SSM in deployed envs)
VITE_API_URL=http://localhost:3001

# Optional
S3_ARTEFACTS_BUCKET=
WALKCROACH_API_KEY=
